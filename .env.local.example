# Warrantee Environment Variables
# Copy this file to .env.local and fill in your values

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://erptubrslnfmkuouczgn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRO_PRICE_ID=your_stripe_pro_price_id_here

# === Resend (Email) ===
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Warrantee <hello@warrantee.io>
EMAIL_SEND_API_SECRET=your_internal_email_send_secret_here

# === HubSpot CRM (optional) ===
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# === OCR ===
# Launch default: Mistral first when MISTRAL_API_KEY is set, then Google Vision fallback if configured.
# OCR_PROVIDER can be auto, mistral, google, google-vision, or tesseract.
OCR_PROVIDER=auto
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_OCR_MODEL=mistral-ocr-latest

# === Google Vision OCR (optional fallback) ===
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# === Production QA / operational readiness (local only) ===
# Used by authenticated Playwright and readiness probes. Keep these out of Vercel unless explicitly needed.
E2E_USER_EMAIL=qa-user@warrantee.io
E2E_USER_PASSWORD=your_local_qa_password_here
# Note: `vercel env pull --environment=production` may write blank values for sensitive secrets.
# The operational readiness script ignores blank local values and verifies OCR/Stripe through production.

# === Push Notifications ===
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# === App ===
NEXT_PUBLIC_APP_URL=https://warrantee.io

# === Cron ===
CRON_SECRET=your_cron_secret_here

# === Production Rate Limiting ===
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
# Keep strict in Vercel/GitHub production security gates. Local CI can use RATE_LIMIT_ALLOW_MEMORY_FALLBACK=1.
RATE_LIMIT_REQUIRE_REDIS=1

# === Data Retention ===
DATA_RETENTION_INGESTION_PAYLOAD_DAYS=90
DATA_RETENTION_OCR_TEXT_DAYS=90
DATA_RETENTION_API_USAGE_DAYS=400
DATA_RETENTION_BATCH_LIMIT=250

# === Document Security Scanner (optional until provider is configured) ===
# POST endpoint that receives a short-lived signed document URL and returns a verdict:
# { "verdict": "clean" | "blocked" | "scan_failed" }
DOCUMENT_SECURITY_SCANNER_URL=https://scanner.example.com/scan
DOCUMENT_SECURITY_SCANNER_TOKEN=your_document_scanner_bearer_token_here
# Set to 1 after the scanner is live to block downloads until security_status is clean.
DOCUMENT_DOWNLOAD_REQUIRE_CLEAN=0

# === Sentry (optional) ===
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_slug_here
SENTRY_PROJECT=your_sentry_project_slug_here
SENTRY_RELEASE=optional_release_name_or_commit_sha

# === Google Analytics (optional) ===
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# === Google Tag Manager (optional) ===
NEXT_PUBLIC_GTM_ID=GTM-N6G95MQL

# === Meta Ads / Instagram Ads Tracking (optional) ===
# Browser Pixel stays disabled until this is set and the visitor grants marketing consent.
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_or_dataset_id_here
# Server-side Conversions API stays disabled until this token is set.
META_CAPI_ACCESS_TOKEN=your_meta_conversions_api_access_token_here
# Optional Meta Events Manager test code for validation before production use.
META_CAPI_TEST_EVENT_CODE=TEST12345
# Optional Graph API version override.
META_GRAPH_API_VERSION=v20.0
